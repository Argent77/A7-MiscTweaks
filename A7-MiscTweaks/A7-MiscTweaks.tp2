BACKUP ~weidu_external/backup/A7-MiscTweaks~
AUTHOR ~Argent77~
VERSION ~1.0~
// ASK_EVERY_COMPONENT

ALWAYS
  // root folder for mutable data
  OUTER_TEXT_SPRINT WORK_FOLDER ~weidu_external~

  ACTION_IF ((FILE_EXISTS ~dlc/sod-dlc.zip~) OR (FILE_EXISTS ~sod-dlc.zip~)) THEN BEGIN
    FAIL @1000  // DLC Merger is required before mods can be installed on this game. Check the readme for more information and a link to download DLC Merger.
  END

  WITH_SCOPE BEGIN
    OUTER_SPRINT include_file ~%MOD_FOLDER%/lib/comp_%COMPONENT_NUMBER%.tph~
    ACTION_IF (FILE_EXISTS ~%include_file%~) BEGIN
      INCLUDE ~%MOD_FOLDER%/lib/always.tph~
      INCLUDE ~%include_file%~
    END ELSE BEGIN
      ABORT @1002 // Selected mod component has not been implemented.
    END
  END
END

README ~A7-MiscTweaks/doc/readme-%LANGUAGE%.txt~ ~A7-MiscTweaks/doc/readme.txt~

LANGUAGE ~English~
         ~en_us~
         ~A7-MiscTweaks/tra/en_us/setup.tra~
         ~A7-MiscTweaks/tra/en_us/mod.tra~
LANGUAGE ~Deutsch~
         ~de_de~
         ~A7-MiscTweaks/tra/en_us/setup.tra~
         ~A7-MiscTweaks/tra/en_us/mod.tra~
         ~A7-MiscTweaks/tra/de_de/setup.tra~
         ~A7-MiscTweaks/tra/de_de/mod.tra~
LANGUAGE ~Francais~
         ~fr_fr~
         ~A7-MiscTweaks/tra/en_us/setup.tra~
         ~A7-MiscTweaks/tra/en_us/mod.tra~
         ~A7-MiscTweaks/tra/fr_fr/setup.tra~
         ~A7-MiscTweaks/tra/fr_fr/mod.tra~


