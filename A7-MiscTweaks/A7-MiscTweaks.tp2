BEGIN @100  // Add "Great Oak's Beacon" ability
REQUIRE_PREDICATE (GAME_IS ~iwdee~) @1001  // This component is not available for your game.
REQUIRE_PREDICATE (NOT FILE_EXISTS_IN_GAME ~cut250a.bcs~) @1003 // This component is not compatible with the current state of the game.
GROUP @1100 // Convenience Tweaks/Cheats
DESIGNATED 100
LABEL ~A7_MISCTWEAKS_GREAT_OAKS_BEACON_IWDEE~


