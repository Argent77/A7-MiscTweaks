REQUIRE_PREDICATE (GAME_IS ~bgee bg2ee eet iwdee~) @1001  // This component is not available for your game.
GROUP @1100 // Convenience Tweaks/Cheats
DESIGNATED 1
LABEL ~A7_MISCTWEAKS_CRITPROTECT_BRACERS~


