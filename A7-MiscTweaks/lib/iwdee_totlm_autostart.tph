>>>>>>>>

COPY_EXISTING ~ar9603.bcs~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    // main game
    LPF get_script_block
      STR_VAR search = EVAL ~^[ %TAB%]*Global("AR1006_VISITED","GLOBAL",1)~
      RET offset size block
    END

    INNER_PATCH_SAVE block ~%block%~ BEGIN
      REPLACE_TEXTUALLY ~^IF$~ ~IF Global("a7#totlm_transition","MYAREA",0)~
      REPLACE_TEXTUALLY ~\(SetGlobal("GAME_OVER","MYAREA",1)\)~ ~\1 SetGlobal("a7#totlm_transition","MYAREA",1)~
      REPLACE_TEXTUALLY ~\(StartMovie("HOWDRAG")[ %TAB%%WNL%]*Wait(1)\)\(.*[%WNL%]*\)*~
                        ~SaveGame(%save_slot%)
                         \1 ApplySpellRES("bdresurr",Player1)
                            ApplySpellRES("bdresurr",Player2)
                            ApplySpellRES("bdresurr",Player3)
                            ApplySpellRES("bdresurr",Player4)
                            ApplySpellRES("bdresurr",Player5)
                            ApplySpellRES("bdresurr",Player6)
                            SmallWait(5)
                            StartCutScene("a7#hct1a")
                          END~
    END

    LPF replace_script_block
      INT_VAR offset size
      STR_VAR block
    END

    // HoW expansion
    LPF get_script_block
      STR_VAR search = EVAL ~^[ %TAB%]*!Global("AR1006_VISITED","GLOBAL",1)~
      RET offset size block
    END

    INNER_PATCH_SAVE block ~%block%~ BEGIN
      REPLACE_TEXTUALLY ~^IF$~ ~IF Global("a7#totlm_transition","MYAREA",0)~
      REPLACE_TEXTUALLY ~\(SetGlobal("GAME_OVER","MYAREA",1)\)~ ~\1 SetGlobal("a7#totlm_transition","MYAREA",1)~
      REPLACE_TEXTUALLY ~\(StartMovie("HOWDRAG")[ %TAB%%WNL%]*Wait(1)\)\(.*[%WNL%]*\)*~
                        ~SaveGame(%save_slot_how%)
                         \1 ApplySpellRES("bdresurr",Player1)
                            ApplySpellRES("bdresurr",Player2)
                            ApplySpellRES("bdresurr",Player3)
                            ApplySpellRES("bdresurr",Player4)
                            ApplySpellRES("bdresurr",Player5)
                            ApplySpellRES("bdresurr",Player6)
                            SmallWait(5)
                            StartCutScene("a7#hct1a")
                          END~
    END

    LPF replace_script_block
      INT_VAR offset size
      STR_VAR block
    END
  END
BUT_ONLY

EXTEND_TOP ~ar9603.bcs~ ~.../inlined/A7-MiscTweaks/iwdee_totlm_transition.baf~

