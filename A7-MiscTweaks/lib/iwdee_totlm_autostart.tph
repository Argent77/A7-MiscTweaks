/**
 * Returns the first script block matching the specified search pattern.
 *
 * STR_VAR search   Search string as regular expression.
 * RET offset       Start offset of the script block. -1 if no match was found.
 * RET block        Content of the script block if a match was found, empty string otherwise.
 */
DEFINE_PATCH_FUNCTION get_script_block
STR_VAR
  search = ~~
RET
  offset
  size
  block
BEGIN
  SET offset = "-1"
  SET size = 0
  SPRINT block ~~

  // empty search string returns the first available script block
  PATCH_IF (~%search%~ STR_EQ ~~) BEGIN
    SPRINT search ~\bTHEN\b~
  END

  SET pos1 = INDEX_BUFFER(~%search%~)
  PATCH_IF (pos1 >= 0) BEGIN
    SET pos1 = RINDEX_BUFFER(CASE_SENSITIVE ~^IF$~ pos1)
    PATCH_IF (pos1 >= 0) BEGIN
      SET pos2 = INDEX_BUFFER(CASE_SENSITIVE ~^END$~ pos1)
      PATCH_IF (pos2 > pos1) BEGIN
        SET pos2 += 3
        SET offset = pos1
        SET size = pos2 - pos1
        READ_ASCII offset block (size)
      END
    END
  END
END

/**
 * Replaces a script block by another.
 *
 * INT_VAR offset   Start offset of the original script block.
 * INT_VAR size     Size (in bytes) of the original script block.
 * STR_VAR block    The new script block to add.
 */
DEFINE_PATCH_FUNCTION replace_script_block
INT_VAR
  offset = 0
  size = 0
STR_VAR
  block = ~~
BEGIN
  PATCH_IF (offset >= 0 && size > 0) BEGIN
    DELETE_BYTES offset size
    SET block_size = STRING_LENGTH ~%block%~
    PATCH_IF (block_size > 0) BEGIN
      INSERT_BYTES offset block_size
      WRITE_ASCIIE offset ~%block%~ (block_size)
    END
  END
END


// calculating first unoccupied save slot
OUTER_SET save_slot = "-1"  // SaveName() slot number
OUTER_SET name_index = 6    // save folder name index
COPY_EXISTING ~savename.2da~ ~override~
  READ_2DA_ENTRIES_NOW savename_table 1
  FOR (row = 3; row < savename_table; ++row) BEGIN
    READ_2DA_ENTRY_FORMER savename_table row 0 slot
    READ_2DA_ENTRY_FORMER savename_table row 1 strref
    PATCH_IF (IS_AN_INT ~slot~ && slot > save_slot) BEGIN
      SET save_slot = slot
      PATCH_IF (IS_AN_INT ~strref~) BEGIN
        GET_STRREF strref name
        INNER_PATCH_SAVE index ~%name%~ BEGIN REPLACE_TEXTUALLY ~0*\([1-9][0-9]*\).*~ ~\1~ END
        PATCH_IF (IS_AN_INT ~index~ && index > name_index) BEGIN
          SET name_index = index
        END
      END
    END
  END
BUT_ONLY

// defining custom savegame slot
OUTER_SET save_slot += 1
OUTER_SET name_index += 1
ACTION_IF (save_slot > 0 && name_index < 20) BEGIN
  OUTER_SET save_slot_how = save_slot
  OUTER_SPRINT save_name ~000000000%name_index%-Trials of the Luremaster~
  OUTER_PATCH_SAVE save_name ~%save_name%~ BEGIN
    SET len = STRING_LENGTH ~%name_index%~
    DELETE_BYTES 0 len
  END
  OUTER_SET save_strref = RESOLVE_STR_REF(~%save_name%~)
  APPEND ~savename.2da~ ~%save_slot%         %save_strref%      %save_slot%         1~
END ELSE BEGIN
  OUTER_SET save_slot = 0 // Auto-Save
  OUTER_SET save_slot_how = 3 // Auto-Save-HOW
END

